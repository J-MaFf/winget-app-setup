# Keep PowerShell sources and the generated installer LF-normalized on every platform.
# Without this, core.autocrlf=true rewrites the trailing newline to CRLF on Windows
# checkouts, which makes build/Build-WingetInstallScript.ps1 -Check report a false
# "out of date" even when the installer is in sync with the WingetAppSetup module.
*.ps1  text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# The single-file installer is a build artifact assembled from the WingetAppSetup
# module — mark it generated so its 2,400+-line diff collapses in PR review.
winget-app-install.ps1 linguist-generated=true

# Git hooks are POSIX sh scripts run by Git for Windows' sh.exe, which cannot
# execute CRLF files — keep them LF on every checkout.
.githooks/* text eol=lf
